# WPP API credentials
# Get your instance token at https://app.wpp-api.io
INSTANCE_TOKEN=your_instance_token_here
INSTANCE_ID=your-instance-id

# The public hostname where this server is reachable (used to register webhooks)
# Example: myserver.com or 123.456.789.0:3000
PUBLIC_HOST=your-public-host-here

# WPP API base URL (no trailing slash)
WPP_API_URL=https://api.wpp-api.io

# Local port for this server
PORT=3000
